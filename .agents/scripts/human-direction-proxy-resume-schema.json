{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": false,
  "required": ["utterance", "result", "updates", "new_tensions"],
  "properties": {
    "utterance": { "type": "string", "minLength": 1 },
    "result": {
      "enum": [
        "AWAITING_AUTHOR",
        "COMPLETED_ACCEPT",
        "COMPLETED_CHANGE",
        "COMPLETED_HUMAN_DECISION"
      ]
    },
    "updates": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "status", "author_position", "outcome", "effect", "requested_evidence"],
        "properties": {
          "id": { "type": "string", "pattern": "^T[0-9]{3,}$" },
          "status": { "enum": ["open", "resolved"] },
          "author_position": { "type": ["string", "null"], "enum": [null, "DEFEND", "REVISE", "NEED_EVIDENCE", "HUMAN_RESIDUAL"] },
          "outcome": { "type": ["string", "null"], "enum": [null, "changed", "defended-and-clarified", "evidence-found", "empty"] },
          "effect": { "type": ["string", "null"], "enum": [null, "simplified", "removed-work", "complexity-exposed", "premise-corrected", "no-change"] },
          "requested_evidence": { "type": ["string", "null"] }
        }
      }
    },
    "new_tensions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "families", "question", "context_refs", "status", "author_position", "outcome", "effect", "requested_evidence"],
        "properties": {
          "id": { "type": "string", "pattern": "^T[0-9]{3,}$" },
          "families": {
            "type": "array",
            "minItems": 1,
            "items": { "enum": ["concept", "non-entity", "value-cost", "absence", "time-scope", "recurrence", "external-reality", "process"] }
          },
          "question": { "type": "string", "minLength": 1 },
          "context_refs": { "type": "array", "items": { "type": "string" } },
          "status": { "enum": ["open", "resolved"] },
          "author_position": { "type": ["string", "null"], "enum": [null, "DEFEND", "REVISE", "NEED_EVIDENCE", "HUMAN_RESIDUAL"] },
          "outcome": { "type": ["string", "null"], "enum": [null, "changed", "defended-and-clarified", "evidence-found", "empty"] },
          "effect": { "type": ["string", "null"], "enum": [null, "simplified", "removed-work", "complexity-exposed", "premise-corrected", "no-change"] },
          "requested_evidence": { "type": ["string", "null"] }
        }
      }
    }
  }
}
