{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://laplacebench.dev/schemas/agent-request-v1.json",
  "title": "LaplaceBench Agent Request v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "protocol_version",
    "ruleset_id",
    "run_id",
    "game_id",
    "request_id",
    "acting_player",
    "controlled_players",
    "team",
    "context_mode",
    "observation_mode",
    "state"
  ],
  "properties": {
    "protocol_version": { "const": "1.0" },
    "ruleset_id": { "type": "string", "minLength": 1 },
    "run_id": { "type": "string", "minLength": 1 },
    "game_id": { "type": "string", "minLength": 1 },
    "request_id": { "type": "string", "minLength": 1 },
    "acting_player": { "type": "integer", "minimum": 1, "maximum": 4 },
    "controlled_players": {
      "oneOf": [
        { "const": [1, 3] },
        { "const": [2, 4] }
      ]
    },
    "team": { "enum": ["A", "B"] },
    "context_mode": {
      "enum": [
        "persistent-native",
        "persistent-transcript",
        "persistent-agent",
        "public-dialogue"
      ]
    },
    "observation_mode": { "enum": ["json", "ascii", "image", "browser"] },
    "rule_delivery": {
      "enum": ["full-every-turn", "full-once", "compact-card", "state-only"]
    },
    "state": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "board_size",
        "board",
        "current_player",
        "captured_pieces",
        "eliminated_players",
        "ply"
      ],
      "properties": {
        "board_size": { "const": 8 },
        "board": {
          "type": "array",
          "minItems": 8,
          "maxItems": 8,
          "items": {
            "type": "array",
            "minItems": 8,
            "maxItems": 8,
            "items": {
              "oneOf": [
                { "type": "null" },
                {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["player", "void"],
                  "properties": {
                    "player": { "type": "integer", "minimum": 1, "maximum": 4 },
                    "void": { "type": "boolean" }
                  }
                }
              ]
            }
          }
        },
        "current_player": { "type": "integer", "minimum": 1, "maximum": 4 },
        "captured_pieces": {
          "type": "array",
          "minItems": 4,
          "maxItems": 4,
          "items": { "type": "integer", "minimum": 0 }
        },
        "eliminated_players": {
          "type": "array",
          "minItems": 4,
          "maxItems": 4,
          "items": { "type": "boolean" }
        },
        "ply": { "type": "integer", "minimum": 0 },
        "winner": { "type": ["string", "null"], "enum": ["A", "B", null] }
      }
    },
    "legal_moves": {
      "type": "array",
      "items": { "$ref": "#/$defs/move" }
    },
    "opponent_message": { "type": ["string", "null"], "maxLength": 256 },
    "deadline_ms": { "type": "integer", "minimum": 1 }
  },
  "$defs": {
    "position": {
      "type": "array",
      "prefixItems": [
        { "type": "integer", "minimum": 0, "maximum": 7 },
        { "type": "integer", "minimum": 0, "maximum": 7 }
      ],
      "items": false
    },
    "move": {
      "type": "object",
      "additionalProperties": false,
      "required": ["from", "to"],
      "properties": {
        "from": { "$ref": "#/$defs/position" },
        "to": { "$ref": "#/$defs/position" }
      }
    }
  }
}
