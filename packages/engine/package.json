{
  "name": "laplace-engine",
  "version": "1.0.0",
  "description": "Frozen LAPLACE 8x8 rules engine (ruleset laplace-8x8-v1): the deterministic referee used by LaplaceBench. Package versions are immutable ruleset IDs.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc",
    "test": "tsx --test test/**/*.test.ts",
    "typecheck": "tsc --noEmit -p tsconfig.test.json"
  },
  "keywords": [
    "laplace",
    "laplacebench",
    "board-game",
    "llm-benchmark",
    "game-engine"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/keisuke70/laplacebench.git",
    "directory": "packages/engine"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.9.0"
  }
}
